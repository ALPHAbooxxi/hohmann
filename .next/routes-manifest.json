{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/aktuelles",
      "regex": "^/aktuelles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/aktuelles(?:/)?$"
    },
    {
      "page": "/datenschutz",
      "regex": "^/datenschutz(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/datenschutz(?:/)?$"
    },
    {
      "page": "/impressum",
      "regex": "^/impressum(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/impressum(?:/)?$"
    },
    {
      "page": "/kontakt",
      "regex": "^/kontakt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/kontakt(?:/)?$"
    },
    {
      "page": "/links",
      "regex": "^/links(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/links(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/unsere-hunde",
      "regex": "^/unsere\\-hunde(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/unsere\\-hunde(?:/)?$"
    },
    {
      "page": "/unsere-wuerfe",
      "regex": "^/unsere\\-wuerfe(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/unsere\\-wuerfe(?:/)?$"
    },
    {
      "page": "/unsere-zucht",
      "regex": "^/unsere\\-zucht(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/unsere\\-zucht(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}